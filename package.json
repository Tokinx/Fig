{
  "name": "fig",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev --config wrangler.local.jsonc",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy --config wrangler.jsonc"
  },
  "dependencies": {
    "@radix-icons/vue": "^1.0.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "hono": "^4.12.12",
    "qrcode": "^1.5.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "v-calendar": "3.1.2",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.3.1",
    "vue-router": "^5.0.4",
    "vue3-clipboard": "^1.0.0"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.460",
    "@iconify/tailwind": "^1.2.0",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "wrangler": "^4.81.0"
  }
}
